{{ define "run_detail_content" }}
<section class="card">
  <div class="actions" style="justify-content: space-between; align-items: center;">
    <div>
      <div class="muted">Run ID {{ .Run.ID }}</div>
      <strong style="font-size: 22px;">
        <a href="/jobs/{{ .Run.JobID }}">Job #{{ .Run.JobID }}</a>
        {{ if .Job }}<span class="muted">· {{ .Job.Name }}</span>{{ end }}
      </strong>
    </div>
    <div class="actions">
      <a class="btn" href="/runs">Back</a>
      {{ if .CanCancel }}
      <form method="post" action="/runs/{{ .Run.ID }}/cancel" style="display:inline;" onsubmit="return confirm('Cancel this run?');">
        <button class="btn danger" type="submit">Cancel</button>
      </form>
      {{ end }}
    </div>
  </div>
</section>

<section class="card">
  <h2 class="section-title">Summary</h2>
  <div class="meta-list">
    <div class="meta-row"><div class="meta-key">Status</div><div class="meta-value"><span class="{{ statusClass .Run.Status }}">{{ .Run.Status }}</span></div></div>
    <div class="meta-row"><div class="meta-key">Scheduled At</div><div class="meta-value">{{ formatTime .Run.ScheduledAt }}</div></div>
    <div class="meta-row"><div class="meta-key">Started At</div><div class="meta-value">{{ formatTime .Run.StartedAt }}</div></div>
    <div class="meta-row"><div class="meta-key">Finished At</div><div class="meta-value">{{ formatTime .Run.FinishedAt }}</div></div>
    <div class="meta-row"><div class="meta-key">Attempt</div><div class="meta-value">{{ .Run.Attempt }}</div></div>
    <div class="meta-row"><div class="meta-key">Exit Code</div><div class="meta-value">{{ formatValue .Run.ExitCode }}</div></div>
    <div class="meta-row"><div class="meta-key">Error Message</div><div class="meta-value">{{ formatValue .Run.ErrorMessage }}</div></div>
    <div class="meta-row"><div class="meta-key">Log Path</div><div class="meta-value">{{ formatValue .Run.LogPath }}</div></div>
    <div class="meta-row"><div class="meta-key">Result Path</div><div class="meta-value">{{ formatValue .Run.ResultPath }}</div></div>
  </div>
</section>

<section class="card">
  <h2 class="section-title">Events</h2>
  {{ if .Events }}
  <table>
    <thead>
      <tr>
        <th>Time</th>
        <th>Type</th>
        <th>Message</th>
      </tr>
    </thead>
    <tbody>
      {{ range .Events }}
      <tr>
        <td>{{ formatTime .CreatedAt }}</td>
        <td>{{ .EventType }}</td>
        <td>{{ formatValue .Message }}</td>
      </tr>
      {{ end }}
    </tbody>
  </table>
  {{ else }}
  <div class="empty">No events recorded.</div>
  {{ end }}
</section>

<section class="grid two">
  <div class="card">
    <h2 class="section-title">Logs</h2>
    {{ if .LogContent }}
    <pre class="code">{{ .LogContent }}</pre>
    {{ else }}
    <div class="empty">No log content available.</div>
    {{ end }}
  </div>
  <div class="card">
    <h2 class="section-title">Result</h2>
    {{ if .ResultContent }}
    <pre class="code">{{ .ResultContent }}</pre>
    {{ else }}
    <div class="empty">No result content available.</div>
    {{ end }}
  </div>
</section>
{{ end }}
