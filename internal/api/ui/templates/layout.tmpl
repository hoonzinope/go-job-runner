{{ define "base" }}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ .Title }} - job-runner</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #edf2f7;
      --bg-strong: #f7f9fc;
      --panel: rgba(255, 255, 255, 0.94);
      --panel-solid: #ffffff;
      --panel-strong: #f8fbff;
      --text: #162033;
      --muted: #667085;
      --border: #d8e0ec;
      --border-strong: #c8d3e4;
      --accent: #1f5ef3;
      --accent-soft: #eaf1ff;
      --accent-strong: #1748c7;
      --success: #16794c;
      --warn: #9a6700;
      --danger: #b42318;
      --sidebar: #0f172a;
      --sidebar-strong: #111c34;
      --sidebar-border: rgba(148, 163, 184, 0.16);
      --sidebar-muted: rgba(226, 232, 240, 0.7);
      --radius: 18px;
      --radius-lg: 24px;
      --shadow: 0 18px 40px rgba(20, 42, 75, 0.08);
      --shadow-soft: 0 8px 24px rgba(20, 42, 75, 0.05);
    }
    * { box-sizing: border-box; }
    html {
      scroll-behavior: smooth;
    }
    body {
      margin: 0;
      min-height: 100vh;
      font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at top left, rgba(31, 94, 243, 0.08), transparent 36%),
        linear-gradient(180deg, #f8fbff 0%, var(--bg) 100%);
      color: var(--text);
      position: relative;
    }
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(255,255,255,0.22) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.22) 1px, transparent 1px);
      background-size: 84px 84px;
      mask-image: linear-gradient(180deg, rgba(0,0,0,0.18), transparent 72%);
      opacity: 0.12;
      z-index: 0;
    }
    body > * {
      position: relative;
      z-index: 1;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    .app-shell {
      display: grid;
      grid-template-columns: 286px minmax(0, 1fr);
      min-height: 100vh;
    }
    .sidebar {
      position: sticky;
      top: 0;
      align-self: start;
      height: 100vh;
      padding: 20px 18px;
      color: #f8fafc;
      background:
        linear-gradient(180deg, rgba(15, 23, 42, 0.98) 0%, rgba(17, 24, 39, 0.98) 100%);
      border-right: 1px solid var(--sidebar-border);
      box-shadow: inset -1px 0 0 rgba(255,255,255,0.02);
      display: flex;
      flex-direction: column;
      gap: 18px;
    }
    .brand {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: Georgia, "Times New Roman", serif;
      font-size: 18px;
      font-weight: 700;
      letter-spacing: 0.02em;
      color: #fff;
    }
    .brand::before {
      content: "";
      width: 12px;
      height: 12px;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--accent), #66a3ff);
      box-shadow: 0 0 0 6px rgba(31, 94, 243, 0.12);
    }
    .sidebar-brand {
      display: flex;
      flex-direction: column;
      gap: 6px;
      padding: 10px 12px 8px;
      border-radius: 16px;
      background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
      border: 1px solid rgba(255,255,255,0.06);
    }
    .sidebar-brand .brand {
      font-size: 19px;
    }
    .sidebar-kicker {
      color: var(--sidebar-muted);
      font-size: 12px;
      line-height: 1.45;
      max-width: 24ch;
    }
    .sidebar-section {
      display: grid;
      gap: 10px;
      padding: 0 2px;
    }
    .sidebar-label {
      color: rgba(148, 163, 184, 0.92);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 700;
      padding: 0 12px;
    }
    .nav {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .nav a {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 11px 14px;
      border-radius: 14px;
      color: rgba(226, 232, 240, 0.9);
      background: transparent;
      border: 1px solid transparent;
      transition: background 140ms ease, border-color 140ms ease, color 140ms ease, transform 140ms ease, box-shadow 140ms ease;
    }
    .nav a.active {
      color: #fff;
      background: linear-gradient(180deg, rgba(31, 94, 243, 0.96), rgba(23, 72, 199, 0.96));
      border-color: rgba(255,255,255,0.08);
      font-weight: 600;
      box-shadow: 0 10px 28px rgba(31, 94, 243, 0.25);
    }
    .nav a:hover {
      text-decoration: none;
      background: rgba(148, 163, 184, 0.08);
      transform: translateX(2px);
    }
    .sidebar-shortcuts {
      display: grid;
      gap: 8px;
      padding: 0 2px;
    }
    .sidebar-shortcuts .btn {
      justify-content: flex-start;
      width: 100%;
      background: rgba(15, 23, 42, 0.72);
      border-color: rgba(148, 163, 184, 0.2);
      color: #f8fafc;
      box-shadow: none;
    }
    .sidebar-shortcuts .btn.primary {
      background: linear-gradient(180deg, var(--accent), var(--accent-strong));
      border-color: transparent;
    }
    .sidebar-footer {
      margin-top: auto;
      padding: 14px 12px 10px;
      border-top: 1px solid rgba(148, 163, 184, 0.16);
      color: var(--sidebar-muted);
      font-size: 12px;
      line-height: 1.5;
    }
    .workspace {
      min-width: 0;
    }
    main {
      max-width: 1420px;
      margin: 0 auto;
      padding: 22px 28px 40px;
    }
    .page-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
      margin: 18px 0 22px;
      padding: 18px 22px;
      border: 1px solid rgba(208, 219, 233, 0.95);
      border-radius: 20px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(248,251,255,0.92) 100%);
      box-shadow: var(--shadow-soft);
    }
    .page-head h1 {
      margin: 0 0 6px;
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(26px, 2.6vw, 34px);
      line-height: 1.1;
      letter-spacing: -0.02em;
    }
    .page-head p {
      margin: 0;
      color: var(--muted);
      max-width: 72ch;
      line-height: 1.52;
    }
    .card {
      background: var(--panel);
      border: 1px solid rgba(208, 219, 233, 0.95);
      border-radius: 20px;
      padding: 18px;
      box-shadow: var(--shadow-soft);
      backdrop-filter: blur(10px);
    }
    .card + .card { margin-top: 18px; }
    .detail-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.4fr) minmax(300px, 0.9fr);
      gap: 18px;
      align-items: start;
    }
    .detail-stack {
      display: grid;
      gap: 18px;
    }
    .detail-rail {
      display: grid;
      gap: 18px;
      position: sticky;
      top: 96px;
    }
    .hero-surface {
      display: grid;
      gap: 14px;
    }
    .hero-topline {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
      flex-wrap: wrap;
    }
    .hero-kicker {
      color: var(--muted);
      font-size: 13px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      font-weight: 700;
    }
    .hero-title {
      margin: 0;
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(24px, 2.8vw, 34px);
      line-height: 1.1;
      letter-spacing: -0.02em;
    }
    .hero-subtitle {
      margin: 6px 0 0;
      color: var(--muted);
      line-height: 1.55;
      max-width: 72ch;
    }
    .hero-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }
    .metric-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    .metric {
      padding: 12px 14px;
      border-radius: 14px;
      background: linear-gradient(180deg, rgba(248,251,255,0.92), rgba(255,255,255,0.96));
      border: 1px solid rgba(208, 219, 233, 0.95);
    }
    .metric .label {
      display: block;
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-bottom: 6px;
    }
    .metric .value {
      display: block;
      font-weight: 700;
      word-break: break-word;
    }
    .mini-list {
      display: grid;
      gap: 10px;
    }
    .mini-row {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      align-items: baseline;
      padding: 10px 0;
      border-bottom: 1px solid var(--border);
    }
    .mini-row:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }
    .mini-row .label {
      color: var(--muted);
      font-size: 13px;
      font-weight: 600;
    }
    .mini-row .value {
      font-weight: 600;
      text-align: right;
      word-break: break-word;
    }
    .section-toolbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }
    .table-shell {
      width: 100%;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
    }
    .grid {
      display: grid;
      gap: 16px;
    }
    .grid.two {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .grid.three {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    .actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      border: 1px solid var(--border);
      background: var(--panel-solid);
      color: var(--text);
      padding: 9px 14px;
      border-radius: 10px;
      font: inherit;
      cursor: pointer;
      transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease, background 140ms ease, color 140ms ease;
    }
    .btn.secondary {
      background: rgba(15, 23, 42, 0.72);
      border-color: rgba(148, 163, 184, 0.2);
      color: #f8fafc;
    }
    .btn.primary {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }
    .btn.primary:hover {
      background: var(--accent-strong);
      border-color: var(--accent-strong);
    }
    .btn.danger {
      background: #fff;
      border-color: rgba(180, 35, 24, 0.25);
      color: var(--danger);
    }
    .btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 10px 24px rgba(20, 42, 75, 0.08);
      text-decoration: none;
      border-color: var(--border-strong);
    }
    .btn:focus-visible,
    .field input:focus-visible,
    .field select:focus-visible,
    .field textarea:focus-visible {
      outline: 3px solid rgba(31, 94, 243, 0.18);
      outline-offset: 2px;
    }
    .field {
      display: grid;
      gap: 6px;
    }
    .field label {
      font-weight: 600;
      font-size: 13px;
      letter-spacing: 0.01em;
    }
    .field input,
    .field select,
    .field textarea {
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 10px 12px;
      font: inherit;
      background: var(--panel-solid);
      color: var(--text);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.7);
      transition: border-color 140ms ease, box-shadow 140ms ease, transform 140ms ease;
    }
    .field input:hover,
    .field select:hover,
    .field textarea:hover {
      border-color: var(--border-strong);
    }
    .field textarea { min-height: 130px; resize: vertical; }
    table {
      width: 100%;
      border-collapse: collapse;
    }
    .table-shell table {
      min-width: 100%;
    }
    th, td {
      padding: 12px 10px;
      border-bottom: 1px solid var(--border);
      text-align: left;
      vertical-align: top;
    }
    th {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--muted);
      background: rgba(248, 251, 255, 0.95);
      position: sticky;
      top: 0;
      z-index: 1;
    }
    tbody tr:hover td {
      background: rgba(31, 94, 243, 0.03);
    }
    .muted { color: var(--muted); }
    .status {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: 4px 10px;
      font-size: 12px;
      font-weight: 700;
      background: #edf2f7;
      color: var(--text);
    }
    .status-success { background: rgba(22, 121, 76, 0.12); color: var(--success); }
    .status-failed { background: rgba(180, 35, 24, 0.12); color: var(--danger); }
    .status-warn { background: rgba(154, 103, 0, 0.12); color: var(--warn); }
    .status-muted { background: rgba(102, 112, 133, 0.12); color: var(--muted); }
    .code {
      white-space: pre-wrap;
      word-break: break-word;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      font-size: 13px;
      background: #0b1220;
      color: #dbe7ff;
      padding: 16px;
      border-radius: 12px;
      overflow: auto;
    }
    .empty {
      padding: 24px;
      border: 1px dashed var(--border);
      border-radius: var(--radius);
      color: var(--muted);
      text-align: center;
      background: rgba(255,255,255,0.6);
    }
    .meta-list {
      display: grid;
      gap: 10px;
    }
    .meta-row {
      display: grid;
      grid-template-columns: 220px minmax(0, 1fr);
      gap: 16px;
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
    }
    .meta-row:last-child { border-bottom: 0; }
    .meta-key {
      color: var(--muted);
      font-weight: 600;
      font-size: 13px;
    }
    .meta-value { word-break: break-word; }
    .section-title {
      margin: 0 0 14px;
      font-family: Georgia, "Times New Roman", serif;
      font-size: 18px;
      letter-spacing: 0.01em;
    }
    @media (max-width: 960px) {
      .app-shell {
        grid-template-columns: 1fr;
      }
      .sidebar {
        position: relative;
        height: auto;
        border-right: 0;
        border-bottom: 1px solid var(--sidebar-border);
      }
      .sidebar-footer {
        margin-top: 8px;
      }
      .grid.two, .grid.three {
        grid-template-columns: 1fr;
      }
      .detail-grid {
        grid-template-columns: 1fr;
      }
      .detail-rail {
        position: static;
      }
      .page-head {
        flex-direction: column;
        align-items: stretch;
      }
      main {
        padding-inline: 16px;
      }
      .meta-row {
        grid-template-columns: 1fr;
        gap: 4px;
      }
      .table-shell table {
        min-width: 720px;
      }
    }
  </style>
</head>
<body>
  <div class="app-shell">
    <aside class="sidebar">
      <div class="sidebar-brand">
        <div class="brand">job-runner</div>
        <div class="sidebar-kicker">Admin console for jobs, runs, image resolution, and execution control.</div>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-label">Navigation</div>
        <nav class="nav">
          <a href="/jobs" class="{{ if eq .ActiveNav "jobs" }}active{{ end }}">
            <span>Jobs</span>
            <span>01</span>
          </a>
          <a href="/runs" class="{{ if eq .ActiveNav "runs" }}active{{ end }}">
            <span>Runs</span>
            <span>02</span>
          </a>
        </nav>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-label">Quick Actions</div>
        <div class="sidebar-shortcuts">
          <a class="btn primary" href="/jobs/new">New Job</a>
          <a class="btn secondary" href="/jobs">Job List</a>
          <a class="btn secondary" href="/runs">Run History</a>
        </div>
      </div>
      <div class="sidebar-footer">
        UI shell intentionally stays thin. Feature pages carry the task-specific controls.
      </div>
    </aside>
    <section class="workspace">
      <main>
        <div class="page-head">
          <div>
            <h1>{{ .Title }}</h1>
            <p>{{ .Subtitle }}</p>
          </div>
        </div>
        {{ template "page_content" . }}
      </main>
    </section>
  </div>
</body>
</html>
{{ end }}
