{{ define "runs_list_content" }}
<section class="card">
  <div class="actions" style="justify-content: space-between; align-items: center; margin-bottom: 14px;">
    <div>
      <h2 class="section-title" style="margin: 0;">Run Ledger</h2>
      <p class="muted" style="margin: 6px 0 0; max-width: 72ch;">Browse execution history, filter by job and state, then jump into a live run for logs, results, or a cancel action without leaving the console.</p>
    </div>
    <div class="actions">
      <span class="btn" style="cursor: default;">{{ .Pagination.Total }} total</span>
      <a class="btn primary" href="/jobs">Jobs</a>
    </div>
  </div>
  <form method="get" action="/runs" class="grid three">
    <div class="field">
      <label for="jobId">Job ID</label>
      <input id="jobId" name="jobId" value="{{ .Filter.JobID }}" placeholder="Optional job ID">
    </div>
    <div class="field">
      <label for="status">Status</label>
      <select id="status" name="status">
        <option value="" {{ if eq .Filter.Status "" }}selected{{ end }}>All</option>
        <option value="pending" {{ if eq .Filter.Status "pending" }}selected{{ end }}>pending</option>
        <option value="running" {{ if eq .Filter.Status "running" }}selected{{ end }}>running</option>
        <option value="cancelling" {{ if eq .Filter.Status "cancelling" }}selected{{ end }}>cancelling</option>
        <option value="success" {{ if eq .Filter.Status "success" }}selected{{ end }}>success</option>
        <option value="failed" {{ if eq .Filter.Status "failed" }}selected{{ end }}>failed</option>
        <option value="timeout" {{ if eq .Filter.Status "timeout" }}selected{{ end }}>timeout</option>
        <option value="cancelled" {{ if eq .Filter.Status "cancelled" }}selected{{ end }}>cancelled</option>
      </select>
    </div>
    <div class="field">
      <label for="from">From</label>
      <input id="from" name="from" value="{{ .Filter.From }}" placeholder="RFC3339">
    </div>
    <div class="field">
      <label for="to">To</label>
      <input id="to" name="to" value="{{ .Filter.To }}" placeholder="RFC3339">
    </div>
    <div class="actions" style="grid-column: 1 / -1;">
      <button class="btn primary" type="submit">Search</button>
      <a class="btn" href="/runs">Reset</a>
    </div>
  </form>
</section>

<section class="card">
  {{ if .Runs }}
  <div class="table-shell">
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Job</th>
        <th>Scheduled</th>
        <th>Started</th>
        <th>Status</th>
        <th>Attempt</th>
        <th>Exit</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      {{ range .Runs }}
      <tr>
        <td style="white-space: nowrap;"><a href="/runs/{{ .ID }}">{{ .ID }}</a></td>
        <td>
          <div><a href="/jobs/{{ .JobID }}" style="white-space: nowrap;">{{ if .JobName }}{{ .JobName }}{{ else }}Job #{{ .JobID }}{{ end }}</a></div>
          <div class="muted">Job #{{ .JobID }}</div>
        </td>
        <td style="white-space: nowrap;">{{ formatCompactTime .ScheduledAt }}</td>
        <td style="white-space: nowrap;">{{ formatCompactTime .StartedAt }}</td>
        <td><span class="{{ statusClass .Status }}">{{ .Status }}</span></td>
        <td style="white-space: nowrap;">{{ .Attempt }}</td>
        <td style="white-space: nowrap;">{{ formatValue .ExitCode }}</td>
        <td>
          <div class="actions">
            <a class="btn" href="/runs/{{ .ID }}">View</a>
            {{ if .CanCancel }}
            <form method="post" action="/runs/{{ .ID }}/cancel" style="display:inline;" onsubmit="return confirm('Cancel this run?');">
              <button class="btn danger" type="submit">Cancel</button>
            </form>
            {{ end }}
          </div>
        </td>
      </tr>
      {{ end }}
    </tbody>
  </table>
  </div>
  {{ else }}
  <div class="empty">No runs found.</div>
  {{ end }}
</section>

<section class="card">
  <div class="actions" style="justify-content: space-between;">
    <div class="muted">Total {{ .Pagination.Total }} runs</div>
    <div class="actions">
      {{ if .Pagination.HasPrev }}<a class="btn" href="/runs?page={{ .Pagination.PrevPage }}&size={{ .Pagination.Size }}">Prev</a>{{ end }}
      <span class="btn" style="cursor: default;">Page {{ .Pagination.Page }}</span>
      {{ if .Pagination.HasNext }}<a class="btn" href="/runs?page={{ .Pagination.NextPage }}&size={{ .Pagination.Size }}">Next</a>{{ end }}
    </div>
  </div>
</section>
{{ end }}
